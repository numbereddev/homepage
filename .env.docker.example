# Local app URL
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Admin credentials seeded automatically on startup
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-this-immediately

# MySQL connection for local Docker setup
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_DATABASE=numbered_dev
MYSQL_USER=numbered_dev_user
MYSQL_PASSWORD=numbered_dev_password

# Optional custom admin session cookie name
SESSION_COOKIE_NAME=numbered-dev-admin-session
